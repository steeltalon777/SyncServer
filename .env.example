DATABASE_URL=postgresql+asyncpg://sync_user:sync_password@127.0.0.1:5432/sync_db
DATABASE_URL_TEST=postgresql+asyncpg://sync_user:sync_password@127.0.0.1:5432/sync_db
APP_ENV=dev
LOG_LEVEL=INFO
ALLOWED_ORIGINS=
MAX_PUSH_EVENTS=500
DEFAULT_PULL_LIMIT=200

# ============================================================================
# Stand тесты (требуются только для запуска тестов с маркером @pytest.mark.stand)
# ============================================================================

# Обязательные переменные для stand тестов
# SYNC_TEST_MODE=stand                    # Должно быть "stand" для разрешения запуска
# SYNC_TEST_ALLOW_STAND=1                 # Должно быть "1" для подтверждения согласия
# SYNC_TEST_BASE_URL=http://localhost:8000 # Базовый URL поднятого стенда
# SYNC_TEST_ROOT_TOKEN=                   # Root token для аутентификации на стенде

# Опциональные переменные
# SYNC_TEST_RUN_ID=run_$(date +%s)        # Уникальный идентификатор запуска для namespacing
# SYNC_TEST_DB_URL=                       # DSN для прямого доступа к БД стенда (опасно!)
# SYNC_TEST_ALLOW_DIRECT_DB=0             # Должно быть "1" для разрешения прямого доступа к БД
